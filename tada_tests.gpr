with "tada_config.gpr";
with "tada_tests_deps.gpr";
with "tada.gpr";

project Tada_Tests is
   for Source_Dirs use ("tests");
   for Object_Dir use "target/" & Tada_Config.Build_Profile & "/obj-tests";
   for Exec_Dir use "target/" & Tada_Config.Build_Profile & "/bin";
   for Main use ("tests_main.adb");

   package Binder is
      for Default_Switches ("Ada") use Tada_Config.Binder_Switches;
   end Binder;

   package Builder is
      for Executable ("tests_main.adb") use "tests";
      for Default_Switches ("Ada") use Tada_Config.Builder_Switches;
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use Tada_Config.Compiler_Switches;
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Tada_Config.Linker_Switches;
   end Linker;
end Tada_Tests;
